{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-trace-hub.dev/schemas/agent_trace_v1.schema.json",
  "title": "Agent Trace V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "session_id", "source", "metadata", "tools", "messages", "outcome"],
  "properties": {
    "schema": { "const": "agent_trace_v1" },
    "session_id": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "source_format"],
      "properties": {
        "agent": { "type": "string", "minLength": 1 },
        "model": { "type": "string" },
        "provider": { "type": "string" },
        "exported_at": { "type": "string" },
        "cwd": { "type": "string" },
        "source_format": { "type": "string", "minLength": 1 }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/message" }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": true,
      "required": ["quality"],
      "properties": {
        "quality": { "type": "string" }
      }
    }
  },
  "$defs": {
    "content_block": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text"],
          "properties": {
            "type": { "const": "text" },
            "text": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "image" },
            "mime_type": { "type": "string" },
            "data": { "type": "string" }
          }
        }
      ]
    },
    "tool_call": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "arguments"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "arguments": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role"],
      "properties": {
        "role": {
          "enum": ["system", "developer", "user", "assistant", "tool"]
        },
        "content": {
          "type": "array",
          "items": { "$ref": "#/$defs/content_block" }
        },
        "reasoning": {
          "type": "array",
          "items": { "$ref": "#/$defs/content_block" }
        },
        "tool_calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/tool_call" }
        },
        "tool_call_id": { "type": "string" },
        "name": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
