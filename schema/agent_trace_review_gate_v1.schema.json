{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-trace-hub.dev/schemas/agent_trace_review_gate_v1.schema.json",
  "title": "Agent Trace Review Gate V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "input", "reviewer", "method", "status", "summary"],
  "properties": {
    "schema": { "const": "agent_trace_review_gate_v1" },
    "created_at": { "type": "string", "minLength": 1 },
    "input": { "type": "string", "minLength": 1 },
    "reviewer": { "type": "string", "minLength": 1 },
    "method": { "enum": ["manual", "llm"] },
    "status": { "enum": ["approved", "rejected"] },
    "summary": { "type": "string", "minLength": 1 },
    "audit_report": { "type": "string" },
    "approval_report": { "type": "string" },
    "notes": { "type": "string" }
  }
}
