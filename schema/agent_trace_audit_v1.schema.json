{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-trace-hub.dev/schemas/agent_trace_audit_v1.schema.json",
  "title": "Agent Trace Audit V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["input", "schema", "created_at", "profile", "trace_count", "message_count", "finding_count", "blocking_finding_count", "findings", "status"],
  "properties": {
    "input": { "type": "string", "minLength": 1 },
    "schema": { "const": "agent_trace_audit_v1" },
    "created_at": { "type": "string", "minLength": 1 },
    "profile": { "enum": ["local", "private", "public"] },
    "trace_count": { "type": "integer", "minimum": 0 },
    "message_count": { "type": "integer", "minimum": 0 },
    "finding_count": { "type": "integer", "minimum": 0 },
    "blocking_finding_count": { "type": "integer", "minimum": 0 },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "status": { "enum": ["pass", "fail"] }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "detector", "jsonPath", "detail", "evidence", "blocking"],
      "properties": {
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "detector": { "enum": ["literal-secret", "deny-pattern", "credential-pattern", "image"] },
        "jsonPath": { "type": "string", "minLength": 1 },
        "detail": { "type": "string" },
        "evidence": { "type": "string" },
        "blocking": { "type": "boolean" }
      }
    }
  }
}
